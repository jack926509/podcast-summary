# ===== 資料庫 =====
DATABASE_URL="file:./dev.db"

# ===== Groq (Whisper 轉錄主力，便宜 60 倍) =====
# 申請：https://console.groq.com/keys
GROQ_API_KEY="gsk_..."

# ===== OpenAI (Whisper 轉錄備援；Groq 失敗時自動 fallback) =====
OPENAI_API_KEY="sk-..."

# ===== Anthropic (Claude 摘要) =====
ANTHROPIC_API_KEY="sk-ant-..."

# ===== 應用設定 =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== 檔案上傳限制 (bytes, 預設 500MB) =====
MAX_UPLOAD_SIZE="524288000"
